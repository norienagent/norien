{
  "name": "norien",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run build:packages && vitest run",
    "prepare": "npm run build:packages",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "node -e \"require('fs').rmSync('.data',{recursive:true,force:true})\"",
    "openapi": "tsx src/scripts/export-openapi.ts",
    "setup": "npm run db:migrate && npm run db:seed",
    "build:packages": "npm run build --workspace @norien/sdk && npm run build --workspace @norien/tools && npm run build --workspace @norien/runtime && npm run build --workspace @norien/cli",
    "cli": "tsx packages/cli/src/index.ts",
    "cli:link": "npm link --workspace @norien/cli",
    "cli:unlink": "npm unlink --global @norien/cli",
    "dev:web": "npm run dev --workspace @norien/web",
    "build:web": "npm run build --workspace @norien/web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": "true",
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "pg": "^8.22.0",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "packages/*",
    "web"
  ]
}
