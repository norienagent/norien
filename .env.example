# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Public base URL of this registry. Used to build install commands and
# api_endpoint values, so nothing about the host is hardcoded in the code.
PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Leave DATABASE_URL empty to use the embedded PGlite database (zero install,
# stored in PGLITE_DATA_DIR). Set it to a Postgres connection string to run
# against a real server -- the schema and every query are identical.
#
# DATABASE_URL=postgres://user:password@localhost:5432/norien
DATABASE_URL=
PGLITE_DATA_DIR=./.data/pglite
DB_POOL_MAX=10

# ---------------------------------------------------------------------------
# API behaviour
# ---------------------------------------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Seed the sample catalogue (12 tools, 10 agents) when the registry is empty.
# Runs on first boot only, and never in production or tests.
AUTO_SEED=true

# Template used to render an agent's install command. {slug} and {version}
# are substituted at read time.
INSTALL_COMMAND_TEMPLATE=norien install {slug}@{version}

# ---------------------------------------------------------------------------
# Auth. A development principal is resolved from this header for now
# so that ownership rules are already enforced end to end.
# ---------------------------------------------------------------------------
DEV_PRINCIPAL_HEADER=x-norien-actor
DEV_PRINCIPAL_FALLBACK=anonymous

RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# ---------------------------------------------------------------------------
# Production (norien.live)
#
# Nothing below is needed for local development — every value already has a
# working localhost default. Set these on the deployed instances only.
# ---------------------------------------------------------------------------

# Registry (api.norien.live)
#   PUBLIC_BASE_URL is what the registry writes into `api_endpoint` fields, so
#   it must be the public origin, not the internal one.
# PUBLIC_BASE_URL=https://api.norien.live
# DATABASE_URL=postgres://user:password@host:5432/norien
# NODE_ENV=production

# Web app (norien.live)
#   NORIEN_API_URL is read server-side; it may be an internal address if the
#   web app and registry share a private network.
# NORIEN_API_URL=https://api.norien.live
# NEXT_PUBLIC_APP_URL=https://norien.live

# CLI / SDK
#   Overrides the compiled default without rebuilding.
# NORIEN_REGISTRY=https://api.norien.live
