{
  "name": "Browser",
  "slug": "browser",
  "version": "1.0.0",
  "description": "Open a URL and return its title, meta description, and readable text.",
  "category": "browser",
  "runtime": "node",
  "entrypoint": "index.js",
  "input_schema": {
    "type": "object",
    "required": ["url"],
    "properties": { "url": { "type": "string", "format": "uri" } }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "url": { "type": "string" },
      "status": { "type": "integer" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "text_length": { "type": "integer" }
    }
  },
  "permissions": ["network:fetch"],
  "license": "MIT"
}
