{
  "name": "Email",
  "slug": "email",
  "version": "1.0.0",
  "description": "Send an email through an HTTP email provider such as Resend or Postmark.",
  "category": "email",
  "runtime": "node",
  "entrypoint": "index.js",
  "input_schema": {
    "type": "object",
    "required": ["to", "subject", "body"],
    "properties": {
      "to": { "type": "string", "format": "email" },
      "from": { "type": "string", "format": "email" },
      "subject": { "type": "string" },
      "body": { "type": "string" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["delivered"],
    "properties": { "delivered": { "type": "boolean" }, "status": { "type": "integer" } }
  },
  "environment": [
    { "name": "EMAIL_API_URL", "description": "Provider send endpoint.", "required": true, "secret": false },
    { "name": "EMAIL_API_KEY", "description": "Provider API key.", "required": true, "secret": true },
    { "name": "EMAIL_FROM", "description": "Default sender address.", "required": false, "secret": false }
  ],
  "permissions": ["network:fetch", "email:send"],
  "license": "MIT"
}
