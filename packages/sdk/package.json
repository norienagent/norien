{
  "name": "@norien/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Norien agent registry, tool marketplace, and unified data API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "keywords": [
    "norien",
    "agent",
    "registry",
    "sdk",
    "ai-agents",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://norien.live",
  "bugs": {
    "url": "https://norien.live/contact"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norienagent/norien.git",
    "directory": "packages/sdk"
  }
}
